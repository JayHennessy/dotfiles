{
  "autoMode": {
    "enabled": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "superpowers": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    },
    "agents": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "altis-skills": {
      "source": {
        "source": "github",
        "repo": "altis-labs/skills"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "enabledPlugins": {
    "warp@claude-code-warp": true,
    "altis-skills@altis-skills": true,
    "claude-mem@thedotmack": true,
    "caveman@caveman": true
  }
}
