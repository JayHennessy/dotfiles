#!/usr/bin/env bash
set -euo pipefail

# config.toml hash: {{ include "dot_config/mise/config.toml" | sha256sum }}

export PATH="$HOME/.local/bin:$PATH"

if ! command -v mise &>/dev/null; then
    echo "==> mise not found, skipping tool installation."
    exit 0
fi

echo "==> Running mise install (this may take a while)..."
mise install -y

echo "==> Installing pip-based tools..."
if command -v mise &>/dev/null; then
    eval "$(mise activate bash)"

    # bpytop - resource monitor
    if command -v pip &>/dev/null; then
        pip install --user bpytop 2>/dev/null || true
    fi

    # npm-based tools
    if command -v npm &>/dev/null; then
        echo "    Installing tldr..."
        npm install -g tldr 2>/dev/null || true
    fi

    # Claude Code (standalone installer)
    if ! command -v claude &>/dev/null; then
        echo "    Installing Claude Code..."
        curl -fsSL https://claude.ai/install.sh | bash 2>/dev/null || true
    fi

    # Go-based tools
    if command -v go &>/dev/null; then
        echo "    Installing sqltui..."
        go install github.com/nicktrav/sqltui@latest 2>/dev/null || true

        echo "    Installing lazyworktree..."
        go install github.com/chmouel/lazyworktree/cmd/lazyworktree@latest 2>/dev/null || true

        echo "    Installing diffnav..."
        go install github.com/dlvhdr/diffnav@latest 2>/dev/null || true
    fi

    # gh extensions
    if command -v gh &>/dev/null; then
        if ! gh extension list 2>/dev/null | grep -q "dlvhdr/gh-dash"; then
            echo "    Installing gh-dash..."
            gh extension install dlvhdr/gh-dash 2>/dev/null || true
        fi
    fi
fi

echo "==> mise tools installed."
